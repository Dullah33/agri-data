{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        { "handle": "filesystem" },

        {
            "src": "^/$",
            "dest": "/api/index.php"
        },


        {
            "src": "^/pages/(.*)",
            "dest": "/api/pages/$1"
        },


        {
            "src": "^/api/(.*)",
            "dest": "/api/$1"
        }
    ]
}
