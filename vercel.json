{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.4"
        }
    },
    "routes": [
        { "handle": "filesystem" },
        {
            "src": "^/$",
            "dest": "/api/index.php"
        },
        {
            "src": "^/login$",
            "dest": "/api/login.php"
        },
        {
            "src": "^/register$",
            "dest": "/api/register.php"
        },
        {
            "src": "^/logout$",
            "dest": "/api/logout.php"
        },
        {
            "src": "^/admin/dashboard$",
            "dest": "/api/admin/dashboard.php"
        },
        {
            "src": "^/admin/petani$",
            "dest": "/api/admin/petani.php"
        },
        {
            "src": "^/admin/profile$",
            "dest": "/api/admin/profile.php"
        },
        {
            "src": "/admin/lahan",
            "dest": "/api/admin/lahan.php"
        },
        {
            "src": "^/user/dashboard$",
            "dest": "/api/user/dashboard.php"
        },
        {
            "src": "^/user/profile$",
            "dest": "/api/user/profile.php"
        },
        {
            "src": "^/user/lahan$",
            "dest": "/api/user/lahan.php"
        },
        {
            "src": "^/user/panen$",
            "dest": "/api/user/panen.php"
        },
        {
            "src": "^/sync/(.*)$",
            "dest": "/api/sync/$1"
        }
    ]
}
